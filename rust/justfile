# Build/check entry points for the Rust core. Run from `rust/`.

default: check

fmt:
    cargo fmt --manifest-path jaxstanv5-core/Cargo.toml

# The four gates that must pass before every commit.
check:
    cargo fmt --check --manifest-path jaxstanv5-core/Cargo.toml
    cargo clippy --all-targets --manifest-path jaxstanv5-core/Cargo.toml -- -D warnings
    cargo test --manifest-path jaxstanv5-core/Cargo.toml
    cargo build --target wasm32-unknown-unknown --manifest-path jaxstanv5-core/Cargo.toml

wasm-release:
    cargo build --release --target wasm32-unknown-unknown --manifest-path jaxstanv5-core/Cargo.toml

# Put the wasm binary next to the demo page (run after wasm-release).
demo-assets:
    cp jaxstanv5-core/target/wasm32-unknown-unknown/release/jaxstanv5_core.wasm demo/jstan_core.wasm

# Serve the repo root so the demo can fetch the golden-corpus fixtures:
#   just wasm-release demo-assets demo
demo:
    cd .. && python3 -m http.server 8000 --bind 127.0.0.1

# Cross-backend posterior comparison over the golden corpus (needs uv).
check-posterior:
    cd .. && uv run scripts/check_rust_backend_posterior.py
